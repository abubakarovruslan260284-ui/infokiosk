{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Инфокиоск",
  "version": "1.0.1",
  "identifier": "ru.irskom.infokiosk",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Инфокиоск",
        "width": 1080,
        "height": 1920,
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/content-cache/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
